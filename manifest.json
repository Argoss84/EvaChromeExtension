{
  "manifest_version": 3,
  "name": "Evassistant",
  "short_name": "Evassistant",
  "version": "1.2.1",
  "description": "Evassistant : participants de sessions EVA et favoris de réservation.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Evassistant",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting"
  ]
}
