{
  "manifest_version": 3,
  "name": "EVA Participants",
  "version": "1.1.0",
  "description": "Affiche les participants des sessions EVA réservées et de l'historique.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "EvaEvolved.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://app.eva.gg/*",
    "https://api.eva.gg/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.eva.gg/*", "https://www.eva.gg/*"],
      "js": ["page-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}